# =============================================================================
# Insurance Claims Support AI Agent - Environment Configuration
# Copy this file to `.env` and fill in the values you need.
# Never commit your actual `.env` file.
# =============================================================================

# --- App ---------------------------------------------------------------------
APP_ENV=development
API_HOST=0.0.0.0
API_PORT=8000
LOG_LEVEL=INFO

# --- Provider selection --------------------------------------------------
# Which backend actually generates draft recommendations / powers the agent.
# Options: openai | groq | gemini
LLM_PROVIDER=openai

# Which backend generates vector embeddings for RAG.
# Options: openai | gemini | chroma_default (no key needed, local fallback)
EMBEDDING_PROVIDER=openai

# --- OpenAI (default provider for this deployment) ---------------------------
OPENAI_API_KEY=
OPENAI_CHAT_MODEL=gpt-4o
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# --- Groq (optional, alternative LLM_PROVIDER) --------------------------------
GROQ_API_KEY=
GROQ_CHAT_MODEL=llama-3.3-70b-versatile

# --- Google Gemini (optional, alternative LLM_PROVIDER / EMBEDDING_PROVIDER) --
GOOGLE_API_KEY=
GEMINI_CHAT_MODEL=gemini-1.5-flash
GEMINI_EMBEDDING_MODEL=models/text-embedding-004

# --- RAG -----------------------------------------------------------------
RAG_CHUNK_SIZE=800
RAG_CHUNK_OVERLAP=120
RAG_TOP_K=4
CHROMA_COLLECTION_NAME=insurance_knowledge_base

# --- Knowledge Base -------------------------------------------------------
# Optional absolute path to a knowledge base directory that contains markdown files.
# If not set, the app defaults to the workspace `knowledge_base/` folder.
KNOWLEDGE_BASE_PATH=

# --- Memory ----------------------------------------------------------------
MEMORY_TOP_K=5
